int len(str Check) {
  int j = 0;
  while (Check[j] != '\0') {
    j++;
  }
  return j;
}

int SkipWS(str code, int pos) {
  int CodeLen = len(code);
  while (pos < CodeLen) {
    if (code[pos] == '\t' || code[pos] == '\n' || code[pos] == " "[0]) {
      pos = pos + 1;
    } else {
      break;
    }
  }
  return pos;
}

bool is_in(str WordToCheck, list ListToCompare) {
  int zet = 0;
  print("hi\n");
  while (zet < ListToCompare.len) {
    if (WordToCheck == ListToCompare[zet]) {
      return true;
    }
    zet = zet + 1;
  }
  return false;
}

