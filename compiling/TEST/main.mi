struct lst_item {
  ptr next,
  str data
}

class TmpList {
  public {
    ptr init(&self, str data) {
      str first_item = { self, data };
      // Hopefully a pointer conversion method...
      self.start = first_item;
      self.last_item = self.start;
      self.len = 1;
    }

    str get(&self, ptr start, int idx) {
      if (idx > self.len) {
        print("OOB");
        exit(1);
      }
      int i = 0;
      ptr loc = start;
      while (i < idx) {
        loc = loc.next;
      }
      return loc.data;
    }

    int len(&self) { return self.len; }

    void push(&self, str to_add) {
      int i = 0;
      ptr loc = start;
      while (i < self.len) {
        loc = loc.next;
      }
      lst_item addition = { self.start, to_add};
      self.last_item = &addition;
      self.len = self.len + 1;
    }

    void print_list(&self) {
      int i = 0;
      ptr loc = self.start;
      print("[");
      while (i < self.len) {
        print(loc.data, ", ");
        loc = loc.next;
      }
      print("]\n");
    }
  }

  private {
    int len;
    ptr start;
    ptr last_item;
  }
}

